<%- include('../partials/header', { title }) %>
<section class="page-head">
  <div>
    <h1>Attendance analytics</h1>
    <p>Cutoff threshold currently set to <strong><%= cutoffPercent %>%</strong>.</p>
  </div>
  <div class="page-actions">
    <a class="button ghost" href="/settings/notifications">Adjust settings</a>
    <a class="button" href="/export/attendance.csv">Export CSV</a>
  </div>
</section>

<section class="stat-grid">
  <div class="stat">
    <div class="stat-label">Total sessions</div>
    <div class="stat-value"><%= totalSessions %></div>
  </div>
  <div class="stat">
    <div class="stat-label">Total students</div>
    <div class="stat-value"><%= totalStudents %></div>
  </div>
  <div class="stat">
    <div class="stat-label">Below cutoff</div>
    <div class="stat-value"><%= segments.low %></div>
  </div>
</section>

<section class="card">
  <h2>Attendance distribution</h2>
  <div class="bar-row">
    <div class="bar-label">High (90%+)</div>
    <div class="bar-track">
      <div class="bar high" style="width: <%= segmentPercents.high %>%"></div>
    </div>
    <div class="bar-value"><%= segments.high %></div>
  </div>
  <div class="bar-row">
    <div class="bar-label">Medium (<%= cutoffPercent %>% - 89%)</div>
    <div class="bar-track">
      <div class="bar medium" style="width: <%= segmentPercents.medium %>%"></div>
    </div>
    <div class="bar-value"><%= segments.medium %></div>
  </div>
  <div class="bar-row">
    <div class="bar-label">Low (below <%= cutoffPercent %>%)</div>
    <div class="bar-track">
      <div class="bar low" style="width: <%= segmentPercents.low %>%"></div>
    </div>
    <div class="bar-value"><%= segments.low %></div>
  </div>
</section>

<section class="card">
  <h2>Student performance</h2>
  <% if (items.length === 0) { %>
    <p>No students to analyze yet.</p>
  <% } else { %>
    <table class="table">
      <thead>
        <tr>
          <th>Student</th>
          <th>Present sessions</th>
          <th>Attendance %</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% items.forEach((item) => { %>
          <tr>
            <td><%= item.name %> (<%= item.studentId %>)</td>
            <td><%= item.presentCount %> / <%= totalSessions %></td>
            <td><%= item.percent.toFixed(1) %>%</td>
            <td>
              <span class="pill <%= item.flagged ? 'pill-danger' : 'pill-success' %>">
                <%= item.flagged ? 'Below cutoff' : 'On track' %>
              </span>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</section>
<%- include('../partials/footer') %>
