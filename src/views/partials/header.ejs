<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %> | Attendra</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="shell">
    <header class="topbar">
      <div class="brand">
        <span class="brand-mark"></span>
        <div>
          <div class="brand-title">Attendra</div>
          <div class="brand-subtitle">Student attendance</div>
        </div>
      </div>
      <nav class="nav">
        <a class="<%= currentPath === '/' ? 'active' : '' %>" href="/">Overview</a>
        <a class="<%= currentPath.startsWith('/students') ? 'active' : '' %>" href="/students">Students</a>
        <a class="<%= currentPath.startsWith('/attendance') ? 'active' : '' %>" href="/attendance">Attendance</a>
        <a class="<%= currentPath.startsWith('/analytics') ? 'active' : '' %>" href="/analytics">Analytics</a>
        <a class="<%= currentPath.startsWith('/settings') ? 'active' : '' %>" href="/settings">Settings</a>
      </nav>
    </header>
    <main class="content">
